@model BookDetailViewModel
@{
    ViewData["Title"] = Model.Title;
    var reviewLabel = Model.ReviewCount == 0 ? "Chưa có đánh giá từ người đọc" : $"{Model.ReviewCount} lượt đánh giá";
    var selectedRating = 0;
    var durationLabel = Model.IsAudioReady && Model.AudioDurationSeconds is > 0
        ? $"{FormatDuration(Model.AudioDurationSeconds.Value)} audio"
        : $"{Model.ReadingTimeMinutes} phút đọc";
}

<div class="zen-container zen-book-detail-page">
    <section class="zen-book-detail-hero">
        <div class="zen-book-detail-cover-wrap" style="background: @Model.CoverGradient;">
            <img src="@Model.CoverUrl" alt="Bìa sách @Model.Title" class="zen-book-detail-cover" />
        </div>

        <div class="zen-book-detail-main">
            <span class="zen-book-detail-kicker">@Model.Category</span>
            <h1>@Model.Title</h1>
            <p class="zen-book-detail-author">Tác giả: <strong>@Model.Author</strong></p>

            <div class="zen-book-detail-rating">
                <span class="zen-book-detail-score">@(Model.HasRating ? Model.Rating.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture) : "—")</span>
                <span class="zen-book-detail-stars" aria-label="Đánh giá bạn đọc">
                    @for (var star = 1; star <= 5; star++)
                    {
                        var active = Model.HasRating && star <= Math.Round((double)Model.Rating, MidpointRounding.AwayFromZero);
                        <svg class="@(active ? "is-active" : "")" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                    }
                </span>
                <span>@reviewLabel</span>
            </div>

            <div class="zen-book-detail-meta">
                <span>@durationLabel</span>
                <span>@Model.ChaptersCount chương</span>
                <span>@(Model.IsAudioReady ? "Có audio" : "Chưa có audio")</span>
            </div>

            <p class="zen-book-detail-lead">@Model.Introduction</p>

            <div class="zen-book-detail-actions">
                @if (Model.CanRead)
                {
                    <a href="/Home/Read/@Model.Id" class="zen-btn zen-btn-primary">
                        <svg viewBox="0 0 24 24"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                        Đọc sách
                    </a>
                }
                <a href="/Home/Library" class="zen-btn zen-btn-ghost">Quay lại thư viện</a>
            </div>
        </div>
    </section>

    <section class="zen-book-detail-reviews">
        <div class="zen-book-review-header">
            <div>
                <span class="zen-book-review-icon">
                    <svg viewBox="0 0 24 24"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4z"/></svg>
                </span>
                <h2>Đánh giá của bạn đọc (@Model.ReviewCount)</h2>
            </div>
            <div class="zen-book-review-filter" data-review-filter>
                <button type="button" class="zen-book-review-sort" aria-expanded="false" aria-label="Lọc đánh giá" data-review-filter-trigger>
                    <svg viewBox="0 0 24 24"><path d="M3 5h18"/><path d="M6 12h12"/><path d="M10 19h4"/></svg>
                    <span data-review-filter-label>Mới nhất</span>
                </button>
                <div class="zen-book-review-filter-menu" data-review-filter-menu>
                    <button type="button" class="is-active" data-review-filter-option data-review-filter-value="newest">Mới nhất</button>
                    <button type="button" data-review-filter-option data-review-filter-value="oldest">Cũ nhất</button>
                    <button type="button" data-review-filter-option data-review-filter-value="highest">Điểm cao nhất</button>
                    <button type="button" data-review-filter-option data-review-filter-value="lowest">Điểm thấp nhất</button>
                    <button type="button" data-review-filter-option data-review-filter-value="with-comment">Có nội dung</button>
                </div>
            </div>
        </div>

        <div class="zen-book-review-layout">
            <form method="post" action="/Books/Review/@Model.Id" class="zen-book-review-form" autocomplete="off" data-review-form>
                @Html.AntiForgeryToken()
                @if (Model.CanReview)
                {
                    <textarea name="comment" rows="4" maxlength="1200" placeholder="Bạn thấy cuốn sách này hữu ích ở điểm nào?" data-review-comment-input></textarea>
                    <div class="zen-review-divider"></div>
                    <div class="zen-review-footer">
                        <div class="zen-star-rating" aria-label="Chọn số sao">
                            @for (var value = 5; value >= 1; value--)
                            {
                                var selected = selectedRating == value;
                                <input type="radio" id="review-star-@value" name="rating" value="@value" @(selected ? "checked" : null) required autocomplete="off" data-review-rating-input />
                                <label for="review-star-@value" aria-label="@value sao">
                                    <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                </label>
                            }
                        </div>
                        <button type="submit" class="zen-btn zen-btn-primary zen-review-submit-btn" aria-label="Gửi đánh giá">
                            <span>Gửi đánh giá</span>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="22" y1="2" x2="11" y2="13"/>
                                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
                            </svg>
                        </button>
                    </div>
                }
                else
                {
                    <div class="zen-book-review-login">
                        <a href="/Account/Login">Đăng nhập</a> để tham gia đánh giá
                    </div>
                }
            </form>

            <div class="zen-book-review-list">
                @if (Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <article class="zen-book-review-item @(review.CanManage ? "is-manageable" : "")"
                                 data-review-item
                                 data-review-rating="@review.Rating"
                                 data-review-date="@review.CreatedAt.ToUniversalTime().ToString("O")"
                                 data-review-has-comment="@(!string.IsNullOrWhiteSpace(review.Comment)).ToString().ToLowerInvariant()">
                            <div class="zen-book-review-topline">
                                <div class="zen-book-review-user">
                                    <span class="zen-book-review-avatar">@BuildInitials(review.UserName)</span>
                                    <div>
                                        <strong>@review.UserName</strong>
                                        <span>@review.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</span>
                                    </div>
                                </div>
                                @if (review.CanManage)
                                {
                                    <div class="zen-review-actions" data-review-actions>
                                        <button type="button" class="zen-review-action-trigger" data-review-action-trigger aria-expanded="false" aria-label="Mở thao tác đánh giá">
                                            <svg viewBox="0 0 24 24"><circle cx="5" cy="12" r="1.8"/><circle cx="12" cy="12" r="1.8"/><circle cx="19" cy="12" r="1.8"/></svg>
                                        </button>
                                        <div class="zen-review-action-menu" data-review-action-menu>
                                            <button type="button"
                                                    class="zen-review-action-item"
                                                    data-review-edit
                                                    data-review-rating="@review.Rating"
                                                    data-review-comment="@review.Comment">
                                                <svg viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                                                Sửa đánh giá
                                            </button>
                                            <form method="post" action="/Books/Review/@Model.Id/Delete">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="zen-review-action-item is-danger" data-review-delete>
                                                    <svg viewBox="0 0 24 24"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v5"/><path d="M14 11v5"/></svg>
                                                    Xoá đánh giá
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="zen-book-review-stars" aria-label="@review.Rating sao">
                                @for (var star = 1; star <= 5; star++)
                                {
                                    <svg class="@(star <= review.Rating ? "is-active" : "")" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(review.Comment))
                            {
                                <p>@review.Comment</p>
                            }
                        </article>
                    }
                }
                else
                {
                    <div class="zen-book-review-empty">Chưa có đánh giá từ bạn đọc. Bạn có thể là người đầu tiên để lại cảm nhận.</div>
                }
                <div class="zen-book-review-empty is-filter-empty" data-review-filter-empty hidden>Không có đánh giá phù hợp với bộ lọc này.</div>
            </div>
        </div>
    </section>
</div>

@functions {
    private static string BuildInitials(string name)
    {
        var clean = (name ?? string.Empty).Trim();
        return string.IsNullOrWhiteSpace(clean) ? "L" : clean[..1].ToUpperInvariant();
    }

    private static string FormatDuration(int durationSeconds)
    {
        var duration = TimeSpan.FromSeconds(Math.Max(1, durationSeconds));
        return duration.TotalHours >= 1
            ? duration.ToString(@"h\:mm\:ss")
            : duration.ToString(@"mm\:ss");
    }
}

@section Scripts {
    <script src="~/js/review-actions.js" asp-append-version="true"></script>
}
