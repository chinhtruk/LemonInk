<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — LemonInk</title>
    <link rel="icon" type="image/png" href="/favicon.png?v=20260513-icon2" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=20260513-icon2" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400&display=swap" rel="stylesheet" />
    
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <script>
        function togglePassword(btn, inputId) {
            const input = document.getElementById(inputId);
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            
            // Toggle SVG icons
            const eyeIcon = `
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
            `;
            const eyeOffIcon = `
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
            `;
            btn.innerHTML = isPassword ? eyeOffIcon : eyeIcon;
        }
    </script>
</head>
<body class="auth-page">
    @{
        var toastMessages = new List<object>();
        var pageError = ViewData["Error"]?.ToString();
        var accountSuccess = TempData["AccountSuccess"]?.ToString();
        var accountError = TempData["AccountError"]?.ToString();

        if (!string.IsNullOrWhiteSpace(pageError))
        {
            toastMessages.Add(new { message = pageError, tone = "error" });
        }
        if (!string.IsNullOrWhiteSpace(accountSuccess))
        {
            toastMessages.Add(new { message = accountSuccess, tone = "success" });
        }
        if (!string.IsNullOrWhiteSpace(accountError))
        {
            toastMessages.Add(new { message = accountError, tone = "error" });
        }
    }

    @RenderBody()
    @if (toastMessages.Count > 0)
    {
        <script type="application/json" id="lemonToastPayload">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(toastMessages))</script>
    }
    <script src="~/js/toasts.js" asp-append-version="true"></script>
    <script src="~/js/password-strength.js" asp-append-version="true"></script>
</body>
</html>
